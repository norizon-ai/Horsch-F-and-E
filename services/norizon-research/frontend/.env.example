# API Configuration
# Browser-side API URL (used for client-side requests)
VITE_API_BASE_URL=http://localhost:8000/api/v1
# Server-side API URL (used for SSR requests inside Docker containers)
# This should use the Docker service name when running in Docker
VITE_SSR_API_BASE_URL=http://deepsearch:8000/api/v1

# App Configuration
VITE_APP_TITLE=Nora
VITE_APP_DESCRIPTION=Knowledge Search Assistant

# Workflow Service API
VITE_WORKFLOW_API_URL=http://localhost:8001

# Auth0 Configuration (for authentication)
PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
PUBLIC_AUTH0_CLIENT_ID=your_client_id_here
PUBLIC_AUTH0_AUDIENCE=https://your-api-audience.com

# Feature Flags
VITE_ENABLE_SHARE=true
VITE_ENABLE_EXPORT=true
