DATABASE_URL=postgresql+asyncpg://norizon:norizon@localhost:5432/workflows
REDIS_URL=redis://localhost:6379/1
DEEPSEARCH_URL=http://localhost:8000
TRANSCRIPTION_URL=http://localhost:8002
CONFLUENCE_PUBLISHER_URL=http://localhost:8003
OBJECT_STORAGE_URL=http://localhost:9000

# Microsoft Teams Integration (OAuth2 delegated permissions)
WORKFLOW_MS_TENANT_ID=
WORKFLOW_MS_CLIENT_ID=
WORKFLOW_MS_CLIENT_SECRET=
WORKFLOW_MS_REDIRECT_URI=http://localhost:8001/auth/microsoft/callback

# LLM Provider for protocol generation
# For OpenAI: set API key, leave base_url empty
# For IONOS EU: set base_url to https://openai.inference.de-txl.ionos.com/v1/
WORKFLOW_LLM_API_KEY=
# WORKFLOW_LLM_BASE_URL=https://openai.inference.de-txl.ionos.com/v1/
# WORKFLOW_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
WORKFLOW_LLM_MODEL=gpt-4o-mini
WORKFLOW_LLM_TEMPERATURE=0.3
WORKFLOW_LLM_MAX_TOKENS=8000
# Two-pass protocol generation: Pass 1 analyzes structure, Pass 2 extracts fields.
# Better results on long transcripts (>30 min), but doubles LLM call count.
# WORKFLOW_LLM_TWO_PASS=true
