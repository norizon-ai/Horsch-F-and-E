# --- Required ---
# Hugging Face token for pyannote speaker diarization
# 1. Create account at https://huggingface.co
# 2. Accept license at https://huggingface.co/pyannote/speaker-diarization-3.1
# 3. Accept license at https://huggingface.co/pyannote/segmentation-3.0
# 4. Create token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# --- Transcription ---
TRANSCRIPTION_PROVIDER=whisper_local
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
DEFAULT_LANGUAGE=de

# --- Speaker name inference (optional) ---
# Without this, speakers will be labeled "Speaker 0", "Speaker 1", etc.
# With this, the system attempts to identify real names from the transcript
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o-mini
# For IONOS EU: redirect OpenAI client to IONOS endpoint
# LLM_BASE_URL=https://openai.inference.de-txl.ionos.com/v1/
# OPENAI_MODEL=mistralai/Mistral-Small-24B-Instruct

# --- Diarization ---
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# --- Storage ---
UPLOAD_DIR=/tmp/transcription-uploads
DATA_DIR=/tmp/transcription-data

# --- Performance ---
# CPU threads for Whisper + Pyannote. Default: half of available cores.
# Prevents the service from freezing your machine. Set to 0 for unlimited.
# CPU_THREADS=4

# --- Processing ---
MAX_PROCESSING_TIMEOUT=14400

# --- Application ---
DEBUG=false
