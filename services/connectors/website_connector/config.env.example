# Website Connector Configuration
# Copy this file to config.env and customize for your environment
#
# Usage:
#   Local:  source config.env && ./scrape_all.sh
#   Docker: Use env_file in docker-compose.yml

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================

# Comma-separated list of domains to crawl
# These domains will be used with wget --domains flag
DOMAINS="example.com,example.org"

# =============================================================================
# SUBDOMAIN DISCOVERY
# =============================================================================

# Input file containing list of subdomains (output from subfinder)
# Can be comma-separated for multiple files: subdomains_de.txt,subdomains_eu.txt
SUBDOMAIN_FILES="subdomains.txt"

# Output file after filtering (valid HTML-serving websites)
WEBSITES_FILE="valid_websites.txt"

# =============================================================================
# SCRAPING BEHAVIOR
# =============================================================================

# Number of parallel wget jobs
# Guideline by connection speed:
#   < 10 Mbps:   3-5 jobs
#   10-50 Mbps:  8-15 jobs
#   50-100 Mbps: 15-25 jobs
#   100+ Mbps:   20-35 jobs
#   Gigabit+:    30-50 jobs
PARALLEL_JOBS=25

# Output directory for downloaded HTML files
OUTPUT_DIR="temp_html"

# Wait time between requests (seconds, can be decimal like 0.5)
WAIT_TIME=0.5

# Add random wait time (true/false)
RANDOM_WAIT=true

# Timeout for each request (seconds)
TIMEOUT=30

# Maximum number of retries per URL
MAX_RETRIES=3

# Maximum download quota per site (e.g., 500m, 1g, 2g)
# Set to 0 for unlimited (use with caution)
QUOTA_PER_SITE="500m"

# Maximum number of redirects to follow
MAX_REDIRECTS=5

# =============================================================================
# FILE FILTERING
# =============================================================================

# File extensions to reject (comma-separated, no spaces)
# These files will not be downloaded
REJECT_EXTENSIONS="*.pdf,*.zip,*.tar.gz,*.exe,*.dmg,*.jpg,*.jpeg,*.png,*.gif,*.svg,*.ico,*.webp,*.bmp,*.tiff,*.css,*.js"

# URL patterns to reject (regex pattern)
# Used with wget --reject-regex flag
# Excludes session tokens, tracking parameters, etc.
REJECT_URL_PATTERN=".*(\?|&)(session|sid|token|ref|utm_|PHPSESSID)=.*"

# =============================================================================
# HTML TO MARKDOWN CONVERSION
# =============================================================================

# Input directory containing downloaded HTML files
# Should match OUTPUT_DIR from scraping configuration
HTML_INPUT_DIR="temp_html"

# Output directory for converted markdown files
MARKDOWN_OUTPUT_DIR="docsmd"

# HTML elements to remove (comma-separated tag names)
# These elements will be stripped before conversion to markdown
# Common: nav, footer, header, script, style, aside
REMOVE_ELEMENTS="nav,footer,header,script,style"

# CSS selectors to remove (comma-separated)
# Remove elements matching these selectors (class or id)
# Examples: .navigation, #sidebar, .ad-banner, .cookie-notice
REMOVE_SELECTORS=".navigation,.nav,.sidebar,.footer,#navigation,#nav,#sidebar,#footer"

# Number of parallel workers for conversion
# Leave empty to auto-detect (uses CPU count - 1)
# Set lower if you encounter memory issues
PARALLEL_WORKERS=""

# Generate JSONL file with all content (true/false)
# If false, only individual .md files with frontmatter are created
# JSONL can be large (GBs), enable only if needed for batch processing
GENERATE_JSONL=false

# Cleanup HTML files after conversion (true/false)
# Set to true to save disk space after successful conversion
CLEANUP_HTML=false

# =============================================================================
# CHANGE DETECTION (for incremental updates)
# =============================================================================

# Enable change detection for incremental updates
CHANGE_DETECTION_ENABLED=true

# Directory to store state files (.last_run_timestamp, .content_hashes.json, etc.)
STATE_DIR=".state"

# Hash algorithm for content comparison (md5, sha256)
HASH_ALGORITHM="md5"

# =============================================================================
# MESSAGE QUEUE (for downstream processing)
# =============================================================================

# Queue type (rabbitmq, kafka, sqs, redis)
QUEUE_TYPE="rabbitmq"

# Queue connection string (override with secrets in production)
QUEUE_URL="localhost:5672"

# Queue credentials (use environment variables in production)
QUEUE_USER="guest"
QUEUE_PASSWORD="guest"

# Batch size for sending messages
QUEUE_BATCH_SIZE=100

# =============================================================================
# SCHEDULING
# =============================================================================

# Enable scheduled refresh (true/false)
SCHEDULING_ENABLED=false

# Cron expression for refresh schedule (e.g., "0 2 * * *" = daily at 2 AM)
CRON_SCHEDULE="0 2 * * *"

# Timezone for cron schedule
TIMEZONE="UTC"

# =============================================================================
# LOGGING
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL="INFO"

# Log file location (empty = stdout only)
LOG_FILE=""
