# =============================================================================
# Norizon search Microservice Configuration
# =============================================================================
# Copy this file to .env and customize for your deployment
# All settings have sensible defaults - only override what you need
# Environment variables use DR_ prefix

# =============================================================================
# LLM Configuration
# =============================================================================

# LLM provider: openai, anthropic, gpt-oss, ollama
DR_LLM_PROVIDER=gpt-oss

# LLM API endpoint (OpenAI-compatible)
DR_LLM_BASE_URL=http://lme49.cs.fau.de:30000/v1

# API key (use "dummy" for local deployments without auth)
DR_LLM_API_KEY=dummy

# Model to use
DR_LLM_MODEL=openai/gpt-oss-120b

# Generation parameters
DR_LLM_TEMPERATURE=0.2
DR_LLM_MAX_TOKENS=2000
DR_LLM_TIMEOUT=60

# =============================================================================
# Supervisor Configuration
# =============================================================================

# Execution strategy: iterative (one tool at a time) or parallel (all at once)
DR_EXECUTION_STRATEGY=iterative

# Maximum search iterations before stopping
DR_MAX_ITERATIONS=3

# Quality thresholds (0.0 - 1.0)
DR_QUALITY_THRESHOLD=0.7
DR_CONFIDENCE_THRESHOLD=0.6

# =============================================================================
# Prompts Configuration
# =============================================================================

# Path to prompts directory (containing YAML files)
DR_PROMPTS_DIR=prompts

# =============================================================================
# API Configuration
# =============================================================================

# Server bind address and port
DR_API_HOST=0.0.0.0
DR_API_PORT=8000

# =============================================================================
# Observability
# =============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
DR_LOG_LEVEL=INFO

# Log format: json (for production) or text (for development)
DR_LOG_FORMAT=json

# Enable OpenTelemetry/Phoenix tracing
DR_ENABLE_TRACING=true

# Phoenix tracing endpoint
DR_PHOENIX_ENDPOINT=http://localhost:6006/v1/traces

# =============================================================================
# Evaluation / LLM-as-Judge Configuration
# =============================================================================
# Used by scripts/evaluate_answer_quality.py when running with --rigorous flag
# The judge LLM evaluates answer quality separately from the main system LLM

# OpenAI API key for judge model (gpt-4o-mini recommended for cost)
# Set this to enable rigorous evaluation
OPENAI_API_KEY=sk-your-openai-api-key-here

# Alternative: use command line flags:
# python scripts/evaluate_answer_quality.py --rigorous \
#   --judge-provider openai \
#   --judge-model gpt-4o-mini \
#   --judge-api-key sk-...

# Cost estimate for gpt-4o-mini:
# - Input: $0.00015/1K tokens
# - Output: $0.0006/1K tokens
# - Per evaluation (~500 input + ~300 output): ~$0.0003
# - For 78 golden questions: ~$0.12 total

# =============================================================================
# Retriever Configuration (per-retriever, not global)
# =============================================================================
# Note: Search backend configuration is done per-retriever, not globally.
# Each retriever configures its own search backend. Example for Elasticsearch:
#
# In your setup code:
#   backend = ElasticsearchBackend(
#       config=ElasticsearchConfig(
#           url="http://localhost:9200",
#           index="my_docs",
#           search_fields=["title^3", "content"],
#       )
#   )
