    %% Inheritance relationships
    BasePlugin <|-- RecognizerPlugin
    BasePlugin <|-- OperatorPlugin
    BasePlugin <|-- ModelPlugin
    
    RecognizerPlugin <|-- PresidioRecognizerPlugin
    RecognizerPlugin <|-- UserIdRecognizerPlugin
    RecognizerPlugin <|-- CourtReferenceRecognizerPlugin
    RecognizerPlugin <|-- CurrencyRecognizerPlugin
    RecognizerPlugin <|-- FileNumberRecognizerPlugin
    RecognizerPlugin <|-- FlairRecognizerPlugin
    RecognizerPlugin <|-- GermanDateRecognizerPlugin
    RecognizerPlugin <|-- ReferenceCodeRecognizerPlugin
    RecognizerPlugin <|-- TransformersRecognizerPlugin
    RecognizerPlugin <|-- RegexPhoneRecognizerPlugin
    
    OperatorPlugin <|-- PresidioOperatorPlugin
    
    ModelPlugin <|-- FlairModelPlugin
    ModelPlugin <|-- SpacyModelPlugin
    
    %% Composition relationships
    PluginManager --> PluginRegistry : contains
    PluginManager --> PluginLoader : contains
    PluginRegistry --> BasePlugin : manages
    BasePlugin --> PluginMetadata : has
    BasePlugin --> PluginType : uses