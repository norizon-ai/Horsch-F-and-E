:# ====================================================
# DEMO CONFLUENCE ASSISTANT - ENVIRONMENT CONFIG
# ====================================================
# This is for the synthetic TechMech Solutions demo
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----------------------------------------------------
# SERVICE PORTS (Different from main setup)
# ----------------------------------------------------
ELASTICSEARCH_PORT=9201
DEEPRESEARCH_PORT=8001
LANGGRAPH_PORT=2025

# ----------------------------------------------------
# MODEL BACKEND
# ----------------------------------------------------
# OpenAI (Recommended)
OPENAI_API_KEY=your-openai-api-key-here


# Alternative: Groq (uncomment if using)
# GROQ_API_KEY=your-groq-api-key-here

# Alternative: Ollama (uncomment if using local models)
# OLLAMA_BASE_URL=http://ollama:11434

# ----------------------------------------------------
# MODEL SELECTION
# ----------------------------------------------------
# Format: <provider>:<model-name>
SUPERVISOR_MODEL=openai:gpt-4o-mini
RESEARCHER_MODEL=openai:gpt-4o-mini

# ----------------------------------------------------
# SEARCH CONFIGURATION
# ----------------------------------------------------
# Primary search backend
SEARCH_API=elasticsearch

# Elasticsearch index name
ELASTIC_INDEX=demo_confluence_kb
ELASTICSEARCH_INDEX=demo_confluence_kb

# ----------------------------------------------------
# EMBEDDING MODEL
# ----------------------------------------------------
# IMPORTANT: Must match the model used during indexing!
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ----------------------------------------------------
# DEMO DATA CONFIGURATION
# ----------------------------------------------------
# Path to generated confluence data
CONFLUENCE_DATA_DIR=./generated_confluence

# Indexing strategy: RESET (recommended for demo)
INDEX_STRATEGY=RESET

# ----------------------------------------------------
# ADVANCED: RESEARCH CONFIGURATION
# ----------------------------------------------------
# Maximum search depth for iterative research
MAX_SEARCH_DEPTH=2

# Number of search queries per research section
NUMBER_OF_QUERIES=4

# Hybrid search alpha (0.0 = pure semantic, 1.0 = pure lexical)
HYBRID_ALPHA=0.5
