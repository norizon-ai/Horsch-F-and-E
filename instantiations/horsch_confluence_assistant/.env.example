# ====================================================
# HORSCH CONFLUENCE ASSISTANT - ENVIRONMENT CONFIG
# ====================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----------------------------------------------------
# SERVICE PORTS
# ----------------------------------------------------
ELASTICSEARCH_PORT=9200
DEEPRESEARCH_PORT=8000
# OLLAMA_PORT=11434
# SEARXNG_PORT=8080

# Demo identification (for prompt loading)
DEMO_NAME=horsch_confluence_assistant

# ----------------------------------------------------
# MODEL BACKEND (Choose ONE)
# ----------------------------------------------------
# OpenAI (Recommended for production)
OPENAI_API_KEY=

# Alternative: Groq (uncomment if using)
# GROQ_API_KEY=your-groq-api-key-here

# Alternative: Ollama (uncomment if using local models)
# OLLAMA_BASE_URL=http://ollama:11434

# Alternative: Custom OpenAI-compatible API
# CUSTOM_API_URL=https://your-custom-api.example.com/v1
# CUSTOM_API_KEY=your-custom-api-key-here

# ----------------------------------------------------
# MODEL SELECTION
# ----------------------------------------------------
# Format: <provider>:<model-name>
# Examples:
#   - openai:gpt-4o-mini
#   - openai:gpt-4o
#   - groq:llama-3.1-70b-versatile
#   - ollama:llama3.1
SUPERVISOR_MODEL=openai:gpt-4o-mini
RESEARCHER_MODEL=openai:gpt-4o-mini

# ----------------------------------------------------
# SEARCH CONFIGURATION
# ----------------------------------------------------
# Primary search backend: elasticsearch or searxng
SEARCH_API=elasticsearch

# Elasticsearch index name (must match indexed data)
ELASTIC_INDEX=confluence_kb
ELASTICSEARCH_INDEX=confluence_kb
CONFLUENCE_BASE_URL=https://confluence.horsch.com
CONFLUENCE_EXPORT_DIR=./confluence_export

# ----------------------------------------------------
# EMBEDDING MODEL
# ----------------------------------------------------
# IMPORTANT: Must match the model used during indexing!
# Common options:
#   - sentence-transformers/all-MiniLM-L6-v2 (default, 384 dims)
#   - sentence-transformers/all-mpnet-base-v2 (768 dims)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ----------------------------------------------------
# CONFLUENCE DATA INDEXING (for custom data)
# ----------------------------------------------------
# Path to your Confluence export directory (only needed if indexing custom data)
# CONFLUENCE_EXPORT_DIR=/path/to/your/confluence_export

# Indexing strategy: RESET, APPEND, or VERSIONED
# INDEX_STRATEGY=RESET

# ----------------------------------------------------
# OPTIONAL: WEB SEARCH (SearXNG)
# ----------------------------------------------------
# Uncomment and configure if you want to enable web search
# SEARXNG_HOST=http://searxng:8080
# SEARXNG_ALLOWED_DOMAINS=horsch.com,example.com

# ----------------------------------------------------
# ADVANCED: RESEARCH CONFIGURATION
# ----------------------------------------------------
# Maximum search depth for iterative research
# MAX_SEARCH_DEPTH=2

# Number of search queries per research section
# NUMBER_OF_QUERIES=4

# Hybrid search alpha (0.0 = pure semantic, 1.0 = pure lexical)
# HYBRID_ALPHA=0.5
