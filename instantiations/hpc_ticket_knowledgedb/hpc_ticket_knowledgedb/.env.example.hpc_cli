# HPC CLI Configuration Example
# Copy this file to .env and fill in your values

# LLM Configuration
LLM_BASE_URL=http://lme49.cs.fau.de:30000/v1
LLM_MODEL=openai/gpt-oss-120b
LLM_API_KEY=dummy
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=30

# Elasticsearch Configuration
ELASTIC_URL=http://localhost:9200
DOCS_INDEX=docs
TICKETS_INDEX=tickets

# Deep Research Configuration
MAX_ITERATIONS=3
CONFIDENCE_THRESHOLD=0.6
QUALITY_THRESHOLD=0.7
MAX_SEARCH_RESULTS=10

# ClusterCockpit Configuration
CLUSTERCOCKPIT_URL=https://monitoring.nhr.fau.de
# JWT token should be set via: hpc config set clustercockpit.jwt "YOUR_JWT"
# Do NOT put it in this file (it will be stored securely in system keyring)

# Optional: Override default config file location
# HPC_CLI_CONFIG_DIR=~/.config/hpc-cli
