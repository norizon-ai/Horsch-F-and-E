# HPC Ticket Knowledge Database - Environment Configuration

# ==============================================================================
# Service Ports
# ==============================================================================
ELASTICSEARCH_PORT=9200
DR_API_PORT=8001

# ==============================================================================
# LLM Configuration
# ==============================================================================
# LLM endpoint URL (NHR Hub Gateway - publicly accessible)
LLM_BASE_URL=https://hub.nhr.fau.de/api/llmgw/v1

# API key for LLM service (get your key from NHR Hub)
LLM_API_KEY=sk-a9uOWS13GwXfELWArWcnAA

# Model name/identifier (available: gpt-oss-120b, gemma-3-12b-it, Meta-Llama3.2-3B-Instruct_L4, etc.)
LLM_MODEL=gpt-oss-120b

# LLM parameters
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000

# LLM timeout in seconds (how long to wait for LLM responses)
LLM_TIMEOUT=30

# ==============================================================================
# Elasticsearch Configuration
# ==============================================================================
# Elasticsearch indices
DOCS_INDEX=docs
TICKETS_INDEX=tickets
KNOWLEDGEBASE_INDEX=knowledgebase

# Embedding model for semantic search (must match indexing)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ==============================================================================
# Deep Research Configuration
# ==============================================================================
# Maximum research iterations
MAX_ITERATIONS=3

# Quality threshold for stopping research early
QUALITY_THRESHOLD=0.7

# Confidence threshold for answers
CONFIDENCE_THRESHOLD=0.6

# Maximum search results per query
MAX_SEARCH_RESULTS=10

# ==============================================================================
# OpenWebUI Configuration (for local testing)
# ==============================================================================
# OpenWebUI web interface port
OPENWEBUI_PORT=3000

# Allow user signup (false = admin creates users)
OPENWEBUI_ENABLE_SIGNUP=false

# Default role for new users (user or admin)
OPENWEBUI_DEFAULT_ROLE=user

# ==============================================================================
# Docker Configuration (for production deployment)
# ==============================================================================
# Docker registry for pushing images
DOCKER_REGISTRY=lisarebecca
DOCKER_USERNAME=lisarebecca

# Image tags
DR_API_IMAGE_TAG=latest
INDEXER_IMAGE_TAG=latest
