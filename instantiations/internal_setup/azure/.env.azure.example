# Azure deployment config for Norizon internal setup
# Copy to .env.azure and fill in values:
#   cp .env.azure.example .env.azure

# Azure subscription (MS for Startups)
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Resource names (defaults match Bicep parameters — only change if needed)
AZURE_RESOURCE_GROUP=norizon-internal-rg
AZURE_LOCATION=swedencentral
AZURE_ACR_NAME=norizonacr
AZURE_KV_NAME=norizon-internal-kv

# Deepgram API key (not in any local .env file, so set it here)
DEEPGRAM_API_KEY=your-deepgram-api-key

# Frontend build args — MUST be set before running deploy-services.sh
# After setup-infra.sh, copy the ACA FQDNs from its output:
#   VITE_DEEPSEARCH_API_URL=https://deepsearch.<random-id>.swedencentral.azurecontainerapps.io
#   VITE_WORKFLOW_API_URL=https://workflow-service.<random-id>.swedencentral.azurecontainerapps.io
# Or if using custom domains:
#   VITE_DEEPSEARCH_API_URL=https://api.internal.norizon.de
#   VITE_WORKFLOW_API_URL=https://workflow.internal.norizon.de
VITE_DEEPSEARCH_API_URL=
VITE_WORKFLOW_API_URL=
